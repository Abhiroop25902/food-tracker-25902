FIREBASE_PROJECT_ID=food-tracker-25902
PORT=8080

# The absolute path to your Google Cloud Service Account key file (.json)
# 1. Go to GCP Console -> IAM & Admin -> Service Accounts
# 2. Create/select a service account and go to 'Keys' tab
# 3. Add Key -> Create New Key -> JSON
# 4. Save it locally and provide the absolute path below
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account-key.json

# If you're using Gemini 1.5 Flash via Vertex AI, the Service Account needs 'Vertex AI User' role.
# If you're using the standard Gemini API key:
GEMINI_API_KEY=your_gemini_api_key_here
